# Containerfile for Gorai Person Detector Service
#
# External service for person detection using YOLOv8 on Hailo-8 NPU.
# This service is defined by its own Service RDL and referenced from the robot RDL.
#
# Prerequisites:
#   Run ./setup-hailo.sh to copy Hailo runtime files before building.
#
# Build:
#   podman build -t localhost/person-detector:latest .
#
# Run (standalone for testing):
#   podman run --rm -it \
#     --device /dev/hailo0 \
#     --network host \
#     -e NATS_URL=nats://localhost:4222 \
#     -e INPUT_COMPONENT=main_camera \
#     -e GORAI_ROBOT_NAME=hello-people-detector \
#     -e GORAI_SERVICE_NAME=person_detector \
#     -v /opt/gorai/models:/models:ro \
#     localhost/person-detector:latest

FROM docker.io/python:3.11-slim-bookworm

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    # OpenCV dependencies
    libgl1 \
    libglib2.0-0 \
    libsm6 \
    libxext6 \
    libxrender1 \
    # Fonts for annotations
    fonts-dejavu-core \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy Hailo runtime library (from setup-hailo.sh)
COPY hailo_runtime/lib/libhailort* /usr/lib/
RUN ldconfig

# Copy Hailo Python bindings (from setup-hailo.sh)
COPY hailo_runtime/python/hailo_platform /usr/local/lib/python3.11/site-packages/hailo_platform

# Copy requirements and install Python dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy application code
COPY config/ ./config/
COPY inference/ ./inference/
COPY processing/ ./processing/
COPY annotate/ ./annotate/
COPY main.py .

# Create non-root user with video group access for device access
RUN useradd -m -u 1000 gorai && \
    usermod -a -G video gorai && \
    chown -R gorai:gorai /app

# Switch to non-root user
USER gorai

# Environment defaults
ENV PYTHONUNBUFFERED=1
ENV LOG_LEVEL=info
ENV NATS_URL=nats://localhost:4222
ENV MODEL_PATH=/models/yolov8s_h8.hef
ENV CONFIDENCE_THRESHOLD=0.5
ENV INPUT_SIZE=640

# Labels
LABEL org.opencontainers.image.title="Gorai Person Detector Service"
LABEL org.opencontainers.image.description="YOLOv8 person detection service using Hailo-8 NPU"
LABEL org.opencontainers.image.source="https://github.com/emergingrobotics/gorai"
LABEL gorai.service.type="object_detection"
LABEL gorai.service.model="yolov8"
LABEL gorai.service.accelerator="hailo-8"

ENTRYPOINT ["python", "main.py"]
