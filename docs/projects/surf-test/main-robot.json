{
  "$schema": "https://gorai.dev/schemas/rdl-v2.json",
  "version": "2",

  "robot": {
    "name": "main-robot",
    "namespace": "surf-test",
    "description": "Main robot on Raspberry Pi 5 with camera and servo control via remote keyboard"
  },

  "platform": {
    "board": "rpi5",
    "gpio": {
      "chip": 0
    }
  },

  "nats": {
    "url": "nats://0.0.0.0:4222"
  },

  "components": [
    {
      "name": "remote_keyboard",
      "type": "input",
      "model": "remote",
      "log_level": "info",
      "attributes": {
        "topic": "gorai.ground-station.keyboard.events",
        "buffer_size": 100,
        "stale_threshold_ms": 3000,
        "auto_release_on_disconnect": true
      }
    },

    {
      "name": "main_camera",
      "type": "camera",
      "model": "v4l2",
      "log_level": "debug",
      "attributes": {
        "device": "/dev/video0",
        "width": 1280,
        "height": 720,
        "frame_rate": 30,
        "jpeg_quality": 80,
        "publish_to_bus": true,
        "publish_rate_hz": 15,
        "frame_id": "camera_link"
      }
    },

    {
      "name": "pan_servo",
      "type": "pwm",
      "model": "gpiod",
      "log_level": "debug",
      "attributes": {
        "pin": 12,
        "frequency_hz": 50,
        "min_pulse_us": 1000,
        "max_pulse_us": 2000,
        "initial_pulse_us": 1500,
        "hw_mode": "auto"
      }
    },

    {
      "name": "tilt_servo",
      "type": "pwm",
      "model": "gpiod",
      "log_level": "debug",
      "attributes": {
        "pin": 13,
        "frequency_hz": 50,
        "min_pulse_us": 1000,
        "max_pulse_us": 2000,
        "initial_pulse_us": 1500,
        "hw_mode": "auto"
      }
    }
  ],

  "services": [
    {
      "name": "motor_controller",
      "type": "control",
      "model": "keypress_motor_controller",
      "log_level": "trace",
      "attributes": {
        "keyboard_component": "remote_keyboard",
        "motors": [
          {
            "name": "pan",
            "type": "pwm",
            "controlled_component": "pan_servo",
            "forward_key": "d",
            "reverse_key": "a",
            "behavior": {
              "type": "angle",
              "angle": {
                "angle_step": 2.5,
                "min_angle": -90.0,
                "max_angle": 90.0,
                "initial_angle": 0,
                "speed": 1.0
              }
            }
          },
          {
            "name": "tilt",
            "type": "pwm",
            "controlled_component": "tilt_servo",
            "forward_key": "w",
            "reverse_key": "s",
            "behavior": {
              "type": "angle",
              "angle": {
                "angle_step": 2.5,
                "min_angle": -90.0,
                "max_angle": 90.0,
                "initial_angle": 0,
                "speed": 1.0
              }
            }
          }
        ]
      },
      "depends_on": ["remote_keyboard", "pan_servo", "tilt_servo"]
    }
  ],

  "log": {
    "level": "debug",
    "format": "text",
    "output": "stdout"
  },

  "dashboard": {
    "enabled": true,
    "listen": ":8080"
  }
}
