# Gorai Publishing Container
# Includes: Hugo Extended, Pandoc, TeX Live, ImageMagick, pkgsite
#
# Build:
#   podman build -t gorai-publish publish/container/
#
# Usage:
#   podman run --rm -v ${PWD}:/workspace:Z gorai-publish <command>

FROM docker.io/library/golang:1.24-bookworm

# Versions
ARG HUGO_VERSION=0.146.0
ARG PANDOC_VERSION=3.1.11

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    # Python for any scripting needs
    python3 \
    python3-pip \
    python3-venv \
    # TeX Live for PDF generation (minimal set for pandoc)
    texlive-xetex \
    texlive-fonts-recommended \
    texlive-latex-extra \
    texlive-plain-generic \
    lmodern \
    # Image processing
    imagemagick \
    graphicsmagick \
    # SVG handling
    librsvg2-bin \
    # Diagram generation
    graphviz \
    plantuml \
    # General utilities
    curl \
    wget \
    git \
    jq \
    tree \
    # For font handling
    fontconfig \
    fonts-liberation \
    fonts-dejavu \
    # Compression
    zip \
    unzip \
    && rm -rf /var/lib/apt/lists/*

# Install Hugo Extended
RUN ARCH=$(dpkg --print-architecture) && \
    case ${ARCH} in \
        amd64) HUGO_ARCH="linux-amd64" ;; \
        arm64) HUGO_ARCH="linux-arm64" ;; \
        *) echo "Unsupported architecture: ${ARCH}" && exit 1 ;; \
    esac && \
    wget -q "https://github.com/gohugoio/hugo/releases/download/v${HUGO_VERSION}/hugo_extended_${HUGO_VERSION}_${HUGO_ARCH}.deb" -O /tmp/hugo.deb && \
    dpkg -i /tmp/hugo.deb && \
    rm /tmp/hugo.deb && \
    hugo version

# Install Pandoc
RUN ARCH=$(dpkg --print-architecture) && \
    case ${ARCH} in \
        amd64) PANDOC_ARCH="amd64" ;; \
        arm64) PANDOC_ARCH="arm64" ;; \
        *) echo "Unsupported architecture: ${ARCH}" && exit 1 ;; \
    esac && \
    wget -q "https://github.com/jgm/pandoc/releases/download/${PANDOC_VERSION}/pandoc-${PANDOC_VERSION}-1-${PANDOC_ARCH}.deb" -O /tmp/pandoc.deb && \
    dpkg -i /tmp/pandoc.deb && \
    rm /tmp/pandoc.deb && \
    pandoc --version | head -1

# Install pandoc filters
RUN pip3 install --break-system-packages \
    pandoc-mermaid-filter \
    pandoc-include

# Install pkgsite for Go API documentation
RUN go install golang.org/x/pkgsite/cmd/pkgsite@latest

# Install mermaid-cli for diagram rendering (optional, uses node)
# Commented out to keep image size smaller - uncomment if needed
# RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - && \
#     apt-get install -y nodejs && \
#     npm install -g @mermaid-js/mermaid-cli

# Configure ImageMagick policy to allow PDF operations
RUN sed -i 's/rights="none" pattern="PDF"/rights="read|write" pattern="PDF"/' /etc/ImageMagick-6/policy.xml || true

# Set up workspace
WORKDIR /workspace

# Copy entrypoint
COPY entrypoint.sh /usr/local/bin/
RUN chmod +x /usr/local/bin/entrypoint.sh

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
CMD ["help"]
